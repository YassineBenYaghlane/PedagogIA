# Database
POSTGRES_DB=ceb
POSTGRES_USER=ceb
POSTGRES_PASSWORD=ceb
POSTGRES_PORT=5411

# Backend
BACKEND_PORT=8000
# For local (non-docker) backend dev. Compose overrides this to db:5432 in-container.
DATABASE_URL=postgresql://ceb:ceb@localhost:5411/ceb
CORS_ORIGINS=["http://localhost:5173"]
# "dev" or "prod". Selects Django settings module and gates dev-only tools on both backend and frontend.
ENVIRONMENT=dev
ANTHROPIC_API_KEY=
DJANGO_SECRET_KEY=dev-insecure-change-me

# ElevenLabs (voice I/O — text-to-speech + speech-to-text)
# - Voice IDs: pick from elevenlabs.io/app/voice-library (paid plan needed for library voices).
# - TTS model: eleven_multilingual_v2 (best French) | eleven_turbo_v2_5 (faster, slightly lower quality)
# - STT model: scribe_v1
ELEVENLABS_API_KEY=
ELEVENLABS_FEMALE_VOICE_ID=
ELEVENLABS_MALE_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v1
# Per-student monthly TTS char cap. ElevenLabs Starter is 30k chars/mo total;
# 2800 chars × 10 students = 28k with a 2k safety buffer.
TTS_MONTHLY_CHAR_CAP_PER_STUDENT=2800

# Google OAuth (see Google Cloud Console → Credentials → OAuth 2.0 Client ID, type "Web application")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:5173/auth/google/callback

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_OAUTH_CALLBACK_URL=http://localhost:5173/auth/google/callback
