# Database
POSTGRES_DB=ceb
POSTGRES_USER=ceb
POSTGRES_PASSWORD=ceb
POSTGRES_PORT=5411

# Backend
BACKEND_PORT=8000
# For local (non-docker) backend dev. Compose overrides this to db:5432 in-container.
DATABASE_URL=postgresql://ceb:ceb@localhost:5411/ceb
CORS_ORIGINS=["http://localhost:5173"]
DEBUG=true
ANTHROPIC_API_KEY=

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
