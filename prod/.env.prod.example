# Copy this file to .env.prod on the server and fill in the values.
# Never commit .env.prod. chmod 600 on the server.

# ===== Domain / TLS =====
DOMAIN=collegia.be
CADDY_EMAIL=you@example.com

# ===== Database (internal, never exposed on host) =====
POSTGRES_DB=pedagogia
POSTGRES_USER=pedagogia
POSTGRES_PASSWORD=__generate_with__openssl_rand_-base64_32__
DATABASE_URL=postgres://pedagogia:__same_as_POSTGRES_PASSWORD__@db:5432/pedagogia

# ===== Django =====
DJANGO_SECRET_KEY=__generate_with__python_-c_"import secrets; print(secrets.token_urlsafe(64))"__
# localhost is required for the backend container's in-container healthcheck.
DJANGO_ALLOWED_HOSTS=collegia.be,www.collegia.be,localhost
CORS_ORIGINS=https://collegia.be,https://www.collegia.be
CSRF_TRUSTED_ORIGINS=https://collegia.be,https://www.collegia.be
GUNICORN_WORKERS=3
# Admin is mounted at this path. Generate a random slug so /admin/ 404s:
#   python3 -c "import secrets; print('mgmt-' + secrets.token_urlsafe(12))"
# Must end with a slash (urls.py normalises it if missing). Default in dev: admin/
DJANGO_ADMIN_PATH=admin/

# ===== Anthropic (Claude API) =====
ANTHROPIC_API_KEY=
INVESTIGATION_MODEL_PRIMARY=claude-haiku-4-5-20251001
INVESTIGATION_MODEL_ESCALATION=claude-sonnet-4-6

# ===== Google OAuth =====
# In Google Cloud Console, add https://collegia.be/auth/google/callback as a redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=https://collegia.be/auth/google/callback
